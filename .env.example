# ---- gateway ----
# testnet = Base Sepolia + x402.org facilitator, mainnet = Base + CDP facilitator
X402_NETWORK=testnet
PORT=8402

# Address (not key!) of the wallet that receives USDC revenue
PAY_TO_ADDRESS=0xYOUR_RECEIVING_WALLET_ADDRESS

# Leave unset to use the network default facilitator
# FACILITATOR_URL=

# ---- mainnet only (phase C) ----
# CDP Secret API key (portal.cdp.coinbase.com -> API keys). Auths the CDP
# facilitator, which is also what indexes you in the Bazaar.
# CDP_API_KEY_ID=
# CDP_API_KEY_SECRET=
# Public URL of the deployment, used as the Bazaar resource URL
# PUBLIC_BASE_URL=https://your-app.up.railway.app

OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1

LEDGER_DB=./ledger.db
MARKUP=1.04
GLOBAL_SPEND_CAP_PER_MIN_USD=5
DEFAULT_MAX_TOKENS=1024
HARD_MAX_TOKENS=8192

# ---- buyer test script only ----
# Private key of the SEPARATE test buyer wallet (never the receiving wallet)
BUYER_PRIVATE_KEY=0x...
GATEWAY_URL=http://localhost:8402
BUYER_MODEL=gpt-4o-mini
